# Copy to .env.local and fill in from Firebase Console → Project Settings → General.
# These values are safe to commit to source control in principle (Firestore rules enforce access),
# but we keep them in .env.local by convention.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Generate key pair
VITE_FIREBASE_VAPID_KEY=

# Deployed Cloudflare Worker URL (e.g. https://smoke-push.your-subdomain.workers.dev)
VITE_PUSH_WORKER_URL=
